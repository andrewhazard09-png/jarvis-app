#!/bin/bash

# Load nvm
export NVM_DIR="$HOME/.nvm"
source "$NVM_DIR/nvm.sh" > /dev/null 2>&1

# Load pyenv
export PYENV_ROOT="$HOME/.pyenv"
export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init -)" > /dev/null 2>&1

cd ~/jarvis-app

# Kill any existing instances
pkill -f "python3 watcher.py" > /dev/null 2>&1
pkill -f "python3 app.py" > /dev/null 2>&1
sleep 1

# Start ollama if not running
pgrep -x ollama > /dev/null || ollama serve > /dev/null 2>&1 &
sleep 2

# Warm phi3
curl -s -X POST http://localhost:11434/api/generate \
  -d '{"model":"phi3","prompt":"","keep_alive":-1}' > /dev/null 2>&1 &

# Start watcher in a new terminal tab
osascript -e 'tell application "Terminal"
  do script "cd ~/jarvis-app && python3 watcher.py"
end tell'

sleep 2

# Open JARVIS
open http://localhost:8080

# Start computer watcher in background
python3 ~/jarvis-app/watcher_mac.py >> ~/jarvis-app/activity.log 2>&1 &
